# Copia este fichero a .env y rellena tus valores reales.
# .env nunca se sube al repo (ver .gitignore).

# development -> cookie de sesión sin flag Secure (permite probar por http en local)
# production  -> cookie de sesión con flag Secure (exige HTTPS)
FLASK_ENV=development

# Clave usada internamente por Flask; pon una cadena larga y aleatoria en producción
SECRET_KEY=clave-secreta

DB_HOST=localhost
DB_USER=root
DB_PASS=contraseña
DB_NAME=reservehub
